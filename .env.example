# Get a free Finnhub API key at https://finnhub.io
# ==============================================================================
# Spy City Environment Variables
# ==============================================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env.local: cp .env.example .env.local
# 2. Fill in your API keys below
# 3. Never commit .env.local to git (already in .gitignore)
#
# ==============================================================================

# ------------------------------------------------------------------------------
# REQUIRED: Finnhub API Key
# ------------------------------------------------------------------------------
# Get your free API key from: https://finnhub.io/register
# Free tier: 60 API calls/minute (sufficient for this app)
#
FINNHUB_API_KEY=your_key_here

# ------------------------------------------------------------------------------
# OPTIONAL: Financial Modeling Prep API Key
# ------------------------------------------------------------------------------
# Currently not used - reserved for future features (historical data, time machine)
# Get your key from: https://financialmodelingprep.com/developer/docs
#
# FMP_API_KEY=your_key_here

# ------------------------------------------------------------------------------
# OPTIONAL: API Base URL Override
# ------------------------------------------------------------------------------
# Override API base URL for development/testing
# Leave empty for production (uses same origin)
#
# NEXT_PUBLIC_API_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# SYSTEM (Auto-detected)
# ------------------------------------------------------------------------------
# NODE_ENV is automatically set by Next.js
# - development: npm run dev
# - production: npm run build && npm start
# - test: npm test
#
# NODE_ENV=development

# FMP (Financial Modeling Prep) — not needed until Stage 4
# Get a free key at https://financialmodelingprep.com
# FMP_API_KEY=your_key_here
